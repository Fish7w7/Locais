# MongoDB
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/servicos-locais?retryWrites=true&w=majority
DNS_SERVERS=1.1.1.1,8.8.8.8

# JWT
JWT_SECRET=sua_chave_secreta_super_forte_aqui_min_32_caracteres
JWT_EXPIRE=7d

# Server local
PORT=5000
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Email / reset de senha
# Em producao, configure uma API key do Resend para o fluxo de "esqueci senha".
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM="Servicos Locais <no-reply@seudominio.com>"

# Rate limiting
# Leituras/polling GET ficam fora do limit global por padrão. Use false para limitar GET também.
RATE_LIMIT_SKIP_READS=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=50
CREATE_RATE_LIMIT_WINDOW_MS=3600000
CREATE_RATE_LIMIT_MAX=200
STRICT_RATE_LIMIT_WINDOW_MS=3600000
STRICT_RATE_LIMIT_MAX=20
